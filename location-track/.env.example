# Pooled Neon connection for the application runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Direct Neon connection for Prisma CLI commands and migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Better Auth configuration.
BETTER_AUTH_SECRET="replace-with-a-strong-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# App URL used to build recheck links in notifications.
APP_URL="http://localhost:3000"

# Secret required by /api/cron/rechecks.
CRON_SECRET="replace-with-a-strong-cron-secret"

# Optional Resend email notifications.
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
